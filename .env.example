# ============================================================
# VOID Player — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- YouTube API ---
# Server-side YouTube Data API v3 key (keeps key off the client)
VOID_YT_API_KEY=

# --- Stream Sources ---
# Comma-separated Piped API instances (optional — built-in defaults used if blank)
# Piped is the primary audio stream source: GET /streams/:videoId
# Find public instances at: https://github.com/TeamPiped/Piped/wiki/Instances
VOID_PIPED_INSTANCES=

# Comma-separated Invidious instances (optional — built-in defaults used if blank)
# Invidious is used for search fallback and as a stream double-fallback
# Find public instances at: https://docs.invidious.io/instances/
VOID_INVIDIOUS_INSTANCES=

# --- CORS ---
# Comma-separated list of allowed origins (leave blank to allow all in dev)
# Example: ALLOWED_ORIGINS=https://your-app.onrender.com
ALLOWED_ORIGINS=

# --- Future: Database (not active yet) ---
# DATABASE_URL=postgres://user:password@host:5432/void_player

# --- Future: Auth / Sessions (not active yet) ---
# SESSION_SECRET=replace_with_a_long_random_string
# JWT_SECRET=replace_with_a_long_random_string

# --- Future: Cloud Sync (not active yet) ---
# STORAGE_BUCKET=
# STORAGE_REGION=
