# ============================================================
# VOID Player — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- YouTube API ---
VOID_YT_API_KEY=

# --- Stream Sources ---
VOID_PIPED_INSTANCES=
VOID_INVIDIOUS_INSTANCES=

# --- CORS ---
ALLOWED_ORIGINS=

# --- Google OAuth (for Drive sync) ---
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → Enable "Google Drive API" + "Google People API"
# 3. OAuth consent screen → External → add your Render domain
# 4. Credentials → OAuth 2.0 Client IDs → Web app
#    Authorized redirect URI: https://your-app.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full callback URL (update with your Render URL in production)
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --- Sessions ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string
